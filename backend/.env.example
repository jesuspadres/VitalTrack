# VitalTrack Backend — Environment Variables
# Copy to .env for local development: cp .env.example .env
# In AWS, these are set via CDK Lambda environment configuration.

# Stage identifier (dev | staging | prod)
STAGE=dev

# DynamoDB table names (CDK creates these with stage suffix)
BIOMARKERS_TABLE_NAME=vitaltrack-biomarkers-dev
INSIGHTS_TABLE_NAME=vitaltrack-insights-dev
AUDIT_LOG_TABLE_NAME=vitaltrack-audit-dev

# S3 bucket for CSV uploads
DATA_BUCKET_NAME=vitaltrack-data-dev

# EventBridge custom event bus
EVENT_BUS_NAME=vitaltrack-events-dev

# Amazon Bedrock model for AI insight generation
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# SNS topic ARN for user notifications (set after deploy)
NOTIFICATION_TOPIC_ARN=

# AWS region (must match your CDK deployment region)
AWS_DEFAULT_REGION=us-east-1
