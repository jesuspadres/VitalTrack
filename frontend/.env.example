# VitalTrack Frontend — Environment Variables
# Copy to .env.local for local development: cp .env.example .env.local
# Vite exposes variables prefixed with VITE_ to the browser.

# AWS region where Cognito and API Gateway are deployed
VITE_AWS_REGION=us-east-1

# Cognito User Pool ID (from CDK output: VitalTrack-Auth-dev.UserPoolId)
VITE_COGNITO_USER_POOL_ID=

# Cognito App Client ID (from CDK output: VitalTrack-Auth-dev.UserPoolClientId)
VITE_COGNITO_CLIENT_ID=

# API Gateway base URL (from CDK output: VitalTrack-Api-dev.ApiUrl)
VITE_API_BASE_URL=
